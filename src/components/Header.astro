---
import { Icon } from "astro-icon/components";
import { site } from "../config";
const base = import.meta.env.BASE_URL;
---

<header class="site-header" id="top">
  <div class="container nav-inner">
    <a class="brand" href={base}>
      <span>{site.name}</span>
    </a>

    <nav class="nav-links" id="navLinks">
      <a href={`${base}#about`}>About</a>
      <a href={`${base}#experience`}>Experience</a>
      <a href={`${base}#work`}>Work</a>
      <a href={`${base}blog`}>Blog</a>
      <a href={`${base}#contact`}>Contact</a>
    </nav>

    <div class="nav-actions">
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">
        <Icon name="lucide:moon" class="icon-moon" />
        <Icon name="lucide:sun" class="icon-sun" />
      </button>
      <button class="nav-burger" id="navBurger" aria-label="Menu"><Icon name="lucide:menu" /></button>
    </div>
  </div>
</header>
