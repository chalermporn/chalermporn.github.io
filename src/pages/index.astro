---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { about, projects, socials } from "../config";

const base = import.meta.env.BASE_URL;

// บล็อก 3 โพสต์ล่าสุด (ไม่เอา draft)
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base>
  <Hero />

  <!-- About -->
  <section class="section" id="about">
    <div class="container">
      <h2 class="section-title">เกี่ยวกับผม</h2>
      <div class="about-text">
        <p>{about.bio}</p>
        <ul class="about-list">
          {about.facts.map((f) => (
            <li><Icon name={`lucide:${f.icon}`} /> {f.label}: <strong>{f.value}</strong></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section class="section" id="work">
    <div class="container">
      <h2 class="section-title">ผลงาน</h2>
      <div class="portfolio-grid">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <!-- Writing -->
  <section class="section section-alt" id="writing">
    <div class="container">
      <h2 class="section-title">บทความล่าสุด</h2>
      <div class="blog-list">
        {posts.map((post) => (
          <a class="blog-row" href={`${base}blog/${post.id}`}>
            <span class="ic"><Icon name={`lucide:${post.data.icon}`} /></span>
            <div>
              <span class="date">{fmt(post.data.date)}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="see-more"><a href={`${base}blog`}>ดูบทความทั้งหมด <Icon name="lucide:arrow-right" /></a></p>
    </div>
  </section>

  <!-- Contact -->
  <section class="section" id="contact">
    <div class="container">
      <h2 class="section-title">ติดต่อ</h2>
      <div class="contact-info">
        <p>อยากชวนทำงาน พูดในงาน หรือคุยเล่น ทักผมได้ตามช่องทางด้านล่างเลยครับ</p>
        <div class="social-list">
          {socials.map((s) => (
            <a href={s.url} title={s.label} aria-label={s.label} target="_blank" rel="noopener"><Icon name={`lucide:${s.icon}`} /></a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
